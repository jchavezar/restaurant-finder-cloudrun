# Local Docker image
IMAGE_NAME=restaurant-finder:local

# Cloud Run deployment target
PROJECT_ID=xxxx
SERVICE_NAME=restaurant-finder
REGION=us-central1
MEMORY=1Gi

# Vertex AI runtime configuration
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_LOCATION=global
MODEL_NAME=gemini-3-flash-preview

# Optional: use an existing Secret Manager secret instead of Vertex AI.
# GEMINI_API_KEY_SECRET=my-gemini-api-key
